#: templates/about.html:4 templates/base.html:20 templates/base.html:60
#: templates/base.html:78
msgid "About"
msgstr "소개"

#: templates/about.html:9
msgid "About B3RC"
msgstr "B3RC 소개"

#: templates/about.html:10
msgid "The Pursuit of Sub-3"
msgstr "서브3를 향한 도전"

#: templates/about.html:11
msgid "Breaking 3 Running Club is a performance-driven community based in Sydney, dedicated to runners chasing the most iconic milestone in amateur marathon running — the sub-3-hour finish."
msgstr "Breaking 3 러닝 클럽은 시드니에 기반한 퍼포먼스 중심의 러닝 커뮤니티로, 아마추어 마라톤의 가장 상징적인 목표인 서브3 완주를 향해 달리는 러너들을 위한 곳입니다."

#: templates/about.html:15
msgid "Targeted Performance"
msgstr "목표 지향적 훈련"

#: templates/about.html:16
msgid "Our collective energy is focused on the sub-3 and sub-3:15 benchmarks, creating a high-level training environment where every session counts."
msgstr "서브3와 서브3:15 달성에 집중하며, 매 훈련이 의미 있는 고수준의 훈련 환경을 만들어갑니다."

#: templates/about.html:19 templates/home.html:102
msgid "Sydney-Based"
msgstr "시드니 기반"

#: templates/about.html:20
msgid "From the Eastern Suburbs to Olympic Park, we utilize Sydney's best terrain to build marathon-ready legs."
msgstr "이스턴 서버브에서 올림픽 파크까지, 시드니 최고의 지형을 활용하여 마라톤에 대비한 다리를 만듭니다."

#: templates/about.html:23
msgid "Inclusive & Ambitious"
msgstr "포용적이면서 도전적인"

#: templates/about.html:24
msgid "We welcome runners of all backgrounds who are ready to commit to their personal bests. Ambition is the only requirement."
msgstr "자기 기록 갱신에 전념할 준비가 된 모든 러너를 환영합니다. 도전 정신만 있으면 됩니다."

#: templates/about.html:27
msgid "The Pack"
msgstr "팩의 힘"

#: templates/about.html:28
msgid "We hunt in packs. You'll never face a grueling 30km long run or interval session alone."
msgstr "우리는 함께 달립니다. 힘든 30km 장거리 달리기나 인터벌 훈련을 혼자 감당할 필요가 없습니다."

#: templates/about.html:33
msgid "Join the Journey"
msgstr "여정에 함께하세요"

#: templates/about.html:34
msgid "The road to a sub-3 marathon is long and incredibly rewarding. Don't chase the clock in isolation — be part of a community that understands what it takes."
msgstr "서브3 마라톤을 향한 길은 길고도 보람찬 여정입니다. 혼자 시간과 싸우지 마세요 — 그 과정을 이해하는 커뮤니티의 일원이 되세요."

#: templates/about.html:35
msgid "Become a Member"
msgstr "회원 가입"

#: templates/activities.html:4 templates/base.html:21 templates/base.html:61
#: templates/base.html:79
msgid "Programs"
msgstr "프로그램"

#: templates/activities.html:9 templates/base.html:94 templates/home.html:41
msgid "Training"
msgstr "훈련"

#: templates/activities.html:10 templates/home.html:42
msgid "Weekly Programs"
msgstr "주간 훈련 프로그램"

#: templates/activities.html:11 templates/home.html:43
msgid "Structured sessions designed to build marathon-ready fitness. Two opportunities each week to train with the pack."
msgstr "마라톤 대비 체력을 기르기 위한 체계적인 훈련. 매주 두 번 팀과 함께 훈련할 기회가 주어집니다."

#: templates/activities.html:15 templates/base.html:95
#: templates/find_us.html:16 templates/home.html:48
msgid "Wednesday — Quality"
msgstr "수요일 — 퀄리티 훈련"

#: templates/activities.html:16
msgid "Midweek quality sessions — intervals, tempo, and race-pace work to sharpen your speed."
msgstr "주중 퀄리티 훈련 — 인터벌, 템포, 레이스 페이스 훈련으로 스피드를 갈고닦습니다."

#: templates/activities.html:17 templates/find_us.html:18
#: templates/home.html:50 templates/home.html:144
msgid "St Lukes Oval, Concord NSW"
msgstr "St Lukes Oval, Concord NSW"

#: templates/activities.html:20 templates/find_us.html:34
#: templates/home.html:54
msgid "Sunday — Long Run"
msgstr "일요일 — 장거리 달리기"

#: templates/activities.html:21 templates/home.html:55
msgid "The cornerstone of marathon preparation. Progressive long runs building endurance and mental resilience."
msgstr "마라톤 준비의 핵심. 점진적 장거리 달리기로 지구력과 정신력을 키웁니다."

#: templates/activities.html:23 templates/find_us.html:36
#: templates/home.html:56 templates/home.html:145
msgid "Rhodes Amphitheatre"
msgstr "Rhodes Amphitheatre"

#: templates/base.html:19 templates/base.html:59 templates/base.html:77
msgid "Home"
msgstr "홈"

#: templates/base.html:22 templates/base.html:62 templates/base.html:84
#: templates/find_us.html:4
msgid "Contact"
msgstr "연락처"

#: templates/base.html:23 templates/base.html:63 templates/base.html:80
#: templates/sponsors.html:4
msgid "Partners"
msgstr "파트너"

#: templates/base.html:27
msgid "Switch language"
msgstr "언어 변경"

#: templates/base.html:48
msgid "Toggle menu"
msgstr "메뉴 전환"

#: templates/base.html:72
msgid "Breaking 3 Running Club — Sydney's pursuit of the sub-3-hour marathon."
msgstr "Breaking 3 러닝 클럽 — 시드니의 서브3 마라톤 도전."

#: templates/base.html:75
msgid "Navigate"
msgstr "탐색"

#: templates/base.html:96
msgid "Sunday — Long Run, 7 AM"
msgstr "일요일 — 장거리 달리기, 오전 7시"

#: templates/base.html:100
msgid "All rights reserved."
msgstr "모든 권리 보유."

#: templates/find_us.html:9 templates/home.html:128
msgid "Locations"
msgstr "훈련 장소"

#: templates/find_us.html:10 templates/home.html:129
msgid "Find Us"
msgstr "오시는 길"

#: templates/find_us.html:11
msgid "We meet at two locations each week across Sydney. Come run with the pack."
msgstr "매주 시드니의 두 장소에서 만납니다. 함께 달려요."

#: templates/find_us.html:17
msgid "Midweek quality sessions."
msgstr "주중 퀄리티 훈련."

#: templates/find_us.html:35
msgid "Progressive long runs, 7 AM start."
msgstr "점진적 장거리 달리기, 오전 7시 출발."

#: templates/find_us.html:52
msgid "Questions?"
msgstr "궁금한 점이 있으신가요?"

#: templates/find_us.html:53
msgid "Reach out anytime — we'd love to hear from you."
msgstr "언제든지 연락 주세요 — 여러분의 소식을 기다립니다."

#: templates/find_us.html:54 templates/home.html:122
msgid "Get in Touch"
msgstr "문의하기"

#: templates/home.html:15
msgid "Breaking 3 Running Club — Sydney"
msgstr "Breaking 3 러닝 클럽 — 시드니"

#: templates/home.html:16
msgid "Train Hard."
msgstr "강하게 훈련하라."

#: templates/home.html:16
msgid "Sweat Hard."
msgstr "땀을 흘려라."

#: templates/home.html:17
msgid "A performance-driven community built around the pursuit of the sub-3-hour marathon. Every session counts."
msgstr "서브3 마라톤을 향한 퍼포먼스 중심 커뮤니티. 매 훈련이 중요합니다."

#: templates/home.html:18
msgid "Join B3RC"
msgstr "B3RC 가입"

#: templates/home.html:30
msgid "About Us"
msgstr "소개"

#: templates/home.html:31
msgid "Where Running Meets Ambition"
msgstr "달리기와 도전이 만나는 곳"

#: templates/home.html:32
msgid "Welcome to B3RC, where running meets community. Whether you're a beginner or an experienced runner, our club offers the perfect environment to help you achieve your personal best. Join us for weekly runs, structured training, and the camaraderie of runners who share your drive."
msgstr "B3RC에 오신 것을 환영합니다. 달리기와 커뮤니티가 만나는 곳입니다. 초보자든 경험 많은 러너든, 개인 최고 기록을 달성할 수 있는 최적의 환경을 제공합니다. 주간 달리기, 체계적 훈련, 그리고 같은 열정을 가진 러너들과의 동료애에 함께하세요."

#: templates/home.html:33
msgid "Learn more"
msgstr "더 알아보기"

#: templates/home.html:49
msgid "Intervals, tempo, and race-pace work to sharpen your speed and lactate threshold."
msgstr "인터벌, 템포, 레이스 페이스 훈련으로 스피드와 젖산 역치를 높입니다."

#: templates/home.html:80
msgid "Why B3RC"
msgstr "왜 B3RC인가"

#: templates/home.html:81
msgid "More Than a Running Club"
msgstr "러닝 클럽 그 이상"

#: templates/home.html:82
msgid "We're a community built on shared ambition, mutual support, and the belief that running is better together."
msgstr "공동의 목표, 상호 지원, 그리고 함께 달리는 것이 더 낫다는 믿음 위에 세워진 커뮤니티입니다."

#: templates/home.html:87
msgid "Performance"
msgstr "퍼포먼스"

#: templates/home.html:88
msgid "Every session is built around the sub-3 goal. Targeted, purposeful training."
msgstr "모든 훈련은 서브3 목표를 중심으로 설계됩니다. 목표 지향적이고 의미 있는 훈련."

#: templates/home.html:92
msgid "Community"
msgstr "커뮤니티"

#: templates/home.html:93
msgid "Hunt in packs. You'll never face a hard session alone."
msgstr "함께 달립니다. 힘든 훈련을 혼자 감당할 필요가 없습니다."

#: templates/home.html:97
msgid "Inclusive"
msgstr "포용"

#: templates/home.html:98
msgid "All backgrounds welcome. Ambition is the only requirement."
msgstr "모든 배경의 러너를 환영합니다. 도전 정신만 있으면 됩니다."

#: templates/home.html:103
msgid "Concord, Rhodes, and the best terrain Sydney has to offer."
msgstr "Concord, Rhodes, 그리고 시드니 최고의 훈련 지형."

#: templates/home.html:107
msgid "Structured"
msgstr "체계적"

#: templates/home.html:108
msgid "Quality midweek sessions and progressive Sunday long runs."
msgstr "주중 퀄리티 훈련과 점진적 일요일 장거리 달리기."

#: templates/home.html:112
msgid "Social"
msgstr "소셜"

#: templates/home.html:113
msgid "Post-run coffee, race-day support, and celebrating every PB."
msgstr "달리기 후 커피, 레이스 당일 응원, 그리고 모든 PB 축하."

#: templates/home.html:120
msgid "Ready to Join B3RC?"
msgstr "B3RC에 합류할 준비가 되셨나요?"

#: templates/home.html:121
msgid "Whether you're chasing your first sub-3 or looking for a dedicated training group in Sydney, your next personal best starts here."
msgstr "첫 서브3에 도전하든, 시드니에서 전문 훈련 그룹을 찾고 있든, 다음 개인 최고 기록은 여기서 시작됩니다."

#: templates/home.html:143
msgid "Training Locations"
msgstr "훈련 장소"

#: templates/home.html:144
msgid "Wednesday"
msgstr "수요일"

#: templates/home.html:145
msgid "Sunday, 7 AM"
msgstr "일요일, 오전 7시"

#: templates/home.html:147 templates/sponsors.html:16
msgid "Contact Us"
msgstr "문의하기"

#: templates/sponsors.html:9
msgid "Partnerships"
msgstr "파트너십"

#: templates/sponsors.html:10
msgid "Our Partners"
msgstr "파트너 소개"

#: templates/sponsors.html:11
msgid "Breaking the 3-hour barrier is a team effort. We partner with brands and businesses that fuel our athletes' ambitions."
msgstr "3시간 벽을 깨는 것은 팀의 노력입니다. 선수들의 도전을 지원하는 브랜드 및 기업과 함께합니다."

#: templates/sponsors.html:14
msgid "Partner with B3RC"
msgstr "B3RC와 파트너 되기"

#: templates/sponsors.html:15
msgid "Interested in supporting Sydney's most ambitious running community? Let's talk."
msgstr "시드니에서 가장 도전적인 러닝 커뮤니티를 후원하고 싶으신가요? 연락 주세요."
